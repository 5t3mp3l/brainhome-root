# Ignore everything by default
*

# Track only specific root-level files
!.gitignore
!BrainHome.code-workspace
!INFRASTRUCTURE.md
!ERLERNTES-WISSEN.md
!TODO.md

# Track workstation tools and docs
!workstation/
workstation/*
!workstation/tools/
workstation/tools/*
!workstation/tools/cluster-inventory.sh
!workstation/scripts/
workstation/scripts/*
!workstation/scripts/remmina-setup-ct113.sh
!workstation/docs/
workstation/docs/*
!workstation/docs/ssh-config.md
!workstation/docs/remmina-client-setup.md

# Track brainhome-cron tool + registry (explicit paths, 3-level deep)
!tools/
!tools/bin/
!tools/bin/brainhome-cron
!tools/config/
!tools/config/cron-registry.json

# Track pihole sync script
!pihole/
!pihole/scripts/
!pihole/scripts/pihole-sync.py

# Track HA addon sync script
!HomeAssistant/
!HomeAssistant/scripts/
!HomeAssistant/scripts/ha-addon-update-sync.py
