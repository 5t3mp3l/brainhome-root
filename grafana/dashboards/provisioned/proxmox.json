{
  "title": "Proxmox Nodes",
  "uid": "brainhome-proxmox",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 10,
      "type": "row",
      "title": "Node Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Nodes Online",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "count(up{job=~\"node_proxmox.*\"} == 1)"
        }
      ],
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 4 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Avg CPU Usage",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "avg(100 - (avg by(host) (rate(node_cpu_seconds_total{mode=\"idle\",job=~\"node_proxmox.*\"}[5m])) * 100))"
        }
      ],
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Avg Memory Usage",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "avg((1 - (node_memory_MemAvailable_bytes{job=~\"node_proxmox.*\"} / node_memory_MemTotal_bytes{job=~\"node_proxmox.*\"})) * 100)"
        }
      ],
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Node Status",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"node_proxmox.*\"}",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 4, "w": 15, "x": 9, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage by Node",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg by(host) (rate(node_cpu_seconds_total{mode=\"idle\",job=~\"node_proxmox.*\"}[5m])) * 100)",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory Usage by Node",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=~\"node_proxmox.*\"} / node_memory_MemTotal_bytes{job=~\"node_proxmox.*\"})) * 100",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Memory Used (absolute)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes{job=~\"node_proxmox.*\"} - node_memory_MemAvailable_bytes{job=~\"node_proxmox.*\"}",
          "legendFormat": "{{host}} used"
        },
        {
          "refId": "B",
          "expr": "node_memory_MemTotal_bytes{job=~\"node_proxmox.*\"}",
          "legendFormat": "{{host}} total"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Disk",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Filesystem Usage % (root)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 - ((node_filesystem_avail_bytes{job=~\"node_proxmox.*\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=~\"node_proxmox.*\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint=\"/\"}) * 100)",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }
      }
    },
    {
      "id": 41,
      "type": "bargauge",
      "title": "Disk Usage (current)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 - ((node_filesystem_avail_bytes{job=~\"node_proxmox.*\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=~\"node_proxmox.*\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint=\"/\"}) * 100)",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network Throughput (receive)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(host) (rate(node_network_receive_bytes_total{job=~\"node_proxmox.*\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))",
          "legendFormat": "{{host}} rx"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Network Throughput (transmit)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(host) (rate(node_network_transmit_bytes_total{job=~\"node_proxmox.*\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))",
          "legendFormat": "{{host}} tx"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 60,
      "type": "row",
      "title": "System Load & Uptime",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },
    {
      "id": 61,
      "type": "timeseries",
      "title": "System Load (1m / 5m / 15m)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "node_load1{job=~\"node_proxmox.*\"}",
          "legendFormat": "{{host}} 1m"
        },
        {
          "refId": "B",
          "expr": "node_load5{job=~\"node_proxmox.*\"}",
          "legendFormat": "{{host}} 5m"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "last"] }
      }
    },
    {
      "id": 62,
      "type": "stat",
      "title": "Uptime",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "time() - node_boot_time_seconds{job=~\"node_proxmox.*\"}",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      }
    },
    {
      "id": 70,
      "type": "row",
      "title": "Temperature",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }
    },
    {
      "id": 71,
      "type": "timeseries",
      "title": "CPU Temperature by Node",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "max by (host) (node_hwmon_temp_celsius{job=~\"node_proxmox.*\",chip=~\"platform_coretemp.*\"})",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 30 },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 75 },
              { "color": "red",    "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 72,
      "type": "gauge",
      "title": "Current Max CPU Temp",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "max by (host) (node_hwmon_temp_celsius{job=~\"node_proxmox.*\",chip=~\"platform_coretemp.*\"})",
          "legendFormat": "{{host}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 30 },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 75 },
              { "color": "red",    "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "tags": ["brainhome", "proxmox", "nodes"]
}
