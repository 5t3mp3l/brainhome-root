# ─────────────────────────────────────────────────────────────
# BrainHome Grafana Stack – Umgebungsvariablen
# Kopie: cp .env.example .env  →  dann Werte anpassen!
# NIEMALS .env in Git committen!
# ─────────────────────────────────────────────────────────────

# Grafana Admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=0248Brain8579

# Grafana URLs
GRAFANA_ROOT_URL=https://grafana.brain

# Image Versionen (auf 'latest' oder pinnen z.B. '10.4.0')
GRAFANA_VERSION=latest
PROMETHEUS_VERSION=latest
LOKI_VERSION=latest

# Grafana Plugins (kommagetrennt, leer = keine)
# Beispiele: grafana-clock-panel,grafana-worldmap-panel
GRAFANA_PLUGINS=

# Prometheus Retention
PROMETHEUS_RETENTION=90d
PROMETHEUS_RETENTION_SIZE=20GB

# Keycloak SSO (nach Client-Anlage in Keycloak ausfüllen)
KEYCLOAK_CLIENT_SECRET=5h7ZzwcZKbVeL9CHAzwJAp26SPySGXb5

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Home Assistant API Tokens (für Prometheus-Scraping)
HA_UG_TOKEN=LONG_LIVED_TOKEN_AUS_HA_UG
HA_EG_TOKEN=LONG_LIVED_TOKEN_AUS_HA_EG
HA_OG_TOKEN=LONG_LIVED_TOKEN_AUS_HA_OG
HA_MASTER_TOKEN=LONG_LIVED_TOKEN_AUS_HA_MASTER
